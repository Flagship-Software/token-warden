{
  "name": "@token-warden/dashboard",
  "version": "0.0.1",
  "private": true,
  "description": "Per-feature LLM cost attribution dashboard with budget alerts and anomaly detection.",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "db:generate": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.sqlite.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed-demo": "tsx src/db/seed-demo.ts",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44.2",
    "geist": "^1.4.1",
    "next": "^15.3.3",
    "pg": "^8.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^2.15.3",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
